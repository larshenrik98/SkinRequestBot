# Discord bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Channel where /skinrequest is allowed (right-click channel → Copy ID)
SKIN_REQUEST_CHANNEL_ID=

# Role allowed to click Approve (right-click role → Copy ID)
SKIN_STAFF_ROLE_ID=

# Rust server command delivery
# pinehost = PineHosting panel API (Mercy default)
# webhook = POST JSON { "command": "..." } to RCON_WEBHOOK_URL
RCON_PROVIDER=pinehost

# PineHosting (when RCON_PROVIDER=pinehost)
PINEHOST_SERVER_ID=
PINEHOST_API_TOKEN=

# Generic webhook (when RCON_PROVIDER=webhook)
RCON_WEBHOOK_URL=
RCON_WEBHOOK_AUTH=
